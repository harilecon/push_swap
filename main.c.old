#include <stdlib.h>
#include "push_swap.h"
#include <stdio.h>
#include <stdlib.h>

int	main(int argc, char **argv)
{

	t_liste	*test;
	t_liste	*lst = NULL;
	t_liste	*tmp;
	long	i;
	char **tab;

	i = 0;
	if (argc <= 1)
	{
		ft_printf("error argument value\n");
		return (1);
	}
	if (argc == 3)
	{
		tab = ft_split(argv[2], ' ');
		if (!tab)
			return (-1);
		while (tab[i])
		{
			test = create_liste(char_lo(tab[i]));
			add_back(&lst, test);
			i++;
		}
	}
	else
	{
		i = 1;
		while (i < argc)
		{
			test = create_liste(char_lo(argv[i]));
			add_back(&lst, test);
			i++;
		}
	}
	indexation(&lst);
	// t_list	*tmp;
	tmp = lst;
	while (tmp)
	{
		printf("%li = %d\n", tmp->value, tmp->index);
		tmp=tmp->next;
	}

	//insertion(&lst);
	// range(&lst);
	// buble(&lst);
	//radix(&lst);

	while (lst)
	{
		tmp = lst->next;
		free(lst);
		lst = tmp;
	}


	while (lst)
	{
		tmp = lst->next;
		free(lst);
		lst = tmp;
	}
	return (0);
}
